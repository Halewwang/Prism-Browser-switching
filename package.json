{
  "name": "prism-app",
  "productName": "Prism",
  "version": "1.10.10",
  "main": "electron/main.js",
  "author": "Hale",
  "type": "module",
  "description": "原生 macOS 浏览器路由选择器",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "test": "node scripts/test-icon-extraction.cjs",
    "sync": "node scripts/sync.js",
    "release": "node scripts/release.js",
    "dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.prism.app",
    "productName": "Prism",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "index.html"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "http",
              "https"
            ],
            "CFBundleURLName": "Web URL Handler",
            "CFBundleTypeRole": "Viewer"
          }
        ]
      }
    },
    "dmg": {
      "title": "Install Prism",
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@google/genai": "^1.0.2",
    "lucide-react": "^0.358.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
